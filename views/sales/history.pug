extends ../layout

block content
  h2.page-title Журнал продаж
  .card
    form(action="/sales/history" method="GET" style="display:flex;gap:10px;margin-bottom:16px")
      .form-group(style="margin:0;flex:1")
        label С
        input.form-control(type="date" name="date_from" value=date_from)
      .form-group(style="margin:0;flex:1")
        label По
        input.form-control(type="date" name="date_to" value=date_to)
      button.btn.btn-primary(type="submit" style="align-self:flex-end") Фильтр
    .table-wrap
      table
        thead
          tr
            th №
            th Дата
            th Фармацевт
            th Покупатель
            th Итого
            th Статус
            th
        tbody
          if sales.length === 0
            tr
              td(colspan=7 style="text-align:center;color:#aaa") Нет данных
          each s in sales
            tr
              td= s.id
              td= new Date(s.created_at).toLocaleString('ru-RU')
              td= s.employee
              td= s.customer || '—'
              td= Number(s.total).toFixed(2) + ' ₽'
              td= s.status === 'completed' ? 'Выполнено' : 'Возврат'
              td
                a.btn.btn-secondary.btn-sm(href=`/sales/${s.id}`) Чек
