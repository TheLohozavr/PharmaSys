doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title || 'Аптека'} — PharmaSys
    link(rel="stylesheet" href="/css/style.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    script(src="https://code.jquery.com/jquery-3.7.1.min.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
  body
    header.navbar
      a.navbar-brand(href="/") 💊 PharmaSys
      nav.navbar-links
        if user
          if user.role === 'admin'
            a(href="/admin") Панель
            a(href="/admin/products") Товары
            a(href="/admin/suppliers") Поставщики
            a(href="/admin/employees") Сотрудники
            a(href="/admin/customers") Покупатели
            a(href="/admin/prescriptions") Рецепты
            a(href="/admin/reports") Отчёты
          else if user.role === 'pharmacist'
            a(href="/") Каталог
            a(href="/sales") Касса
            a(href="/stock") Склад
            a(href="/sales/history") Продажи
            a(href="/orders") Заказы
          else
            a(href="/") Каталог
            a(href="/orders/new") Заказать
            a(href="/orders/my") Мои заказы
          a(href="/profile") Профиль
          span.user-info 👤 #{user.name}
          a(href="/auth/logout") Выйти
        else
          a(href="/") Каталог
          a(href="/auth/login") Войти
          a(href="/auth/register") Регистрация

    main.container
      each msg in success
        .alert.alert-success= msg
      each msg in error
        .alert.alert-danger= msg
      block content

    footer.footer
      p © 2026 PharmaSys. Вариант 18 — Клиент-серверное приложение «Аптека»
    
    // Кастомные скрипты подключаются здесь
    if user && user.role === 'pharmacist'
      script(src="/js/sales.js")
    if user && user.role === 'customer'
      script(src="/js/orders.js")
    
    script.
      $(function() {
        $('.footer').on('mouseenter', function() {
          $(this).css({
            'background-color': '#1a6b3c',
            'color': '#ffffff',
            'transition': 'all 0.3s ease'
          });
        }).on('mouseleave', function() {
          $(this).css({
            'background-color': '',
            'color': ''
          });
        });
        
        // Автоматическое скрытие сообщений через 5 секунд
        setTimeout(function() {
          $('.alert').fadeOut(500, function() {
            $(this).remove();
          });
        }, 5000);
      });