extends ../../layout

block content
  h2.page-title Добавить сотрудника
  .card(style="max-width:500px")
    form(action="/admin/employees" method="POST")
      .form-group
        label ФИО *
        input.form-control(type="text" name="full_name" required)
      .form-row
        .form-group
          label Логин *
          input.form-control(type="text" name="login" required)
        .form-group
          label Пароль *
          input.form-control(type="password" name="password" required)
      .form-group
        label Роль *
        select.form-control(name="role_id" required)
          each r in roles
            option(value=r.id)= r.name
      .form-row
        .form-group
          label Телефон
          input.form-control(type="text" name="phone")
        .form-group
          label Email
          input.form-control(type="email" name="email")
      .form-group
        label Дата приёма на работу
        input.form-control(type="date" name="hired_at")
      div(style="display:flex;gap:8px;margin-top:12px")
        button.btn.btn-primary(type="submit") Сохранить
        a.btn.btn-secondary(href="/admin/employees") Отмена
