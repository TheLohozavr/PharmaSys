extends ../../layout

block content
  h2.page-title Сотрудники
  div(style="margin-bottom:16px")
    a.btn.btn-primary(href="/admin/employees/new") + Добавить сотрудника
  .card
    .table-wrap
      table
        thead
          tr
            th ФИО
            th Логин
            th Роль
            th Телефон
            th Статус
            th Действия
        tbody
          each e in employees
            tr
              td= e.full_name
              td= e.login
              td= e.role_name
              td= e.phone || '—'
              td= e.is_active ? 'Активен' : 'Отключён'
              td
                a.btn.btn-secondary.btn-sm(href=`/admin/employees/${e.id}/edit`) Изменить
                form(action=`/admin/employees/${e.id}/toggle` method="POST" style="display:inline;margin-left:4px")
                  button.btn.btn-sm(class=e.is_active ? 'btn-warning' : 'btn-secondary' type="submit")
                    = e.is_active ? 'Отключить' : 'Включить'
                form(action=`/admin/employees/${e.id}/delete` method="POST" style="display:inline;margin-left:4px")
                  button.btn.btn-danger.btn-sm(type="submit" onclick="return confirm('Удалить сотрудника?')") Удалить