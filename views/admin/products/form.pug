extends ../../layout

block content
  h2.page-title= product ? `Редактировать товар: ${product.name}` : 'Добавить товар'
  
  .card(style="max-width:700px")
    if product
      form(action=`/admin/products/${product.id}/update` method="POST" enctype="multipart/form-data")
        .form-row
          .form-group
            label Наименование *
            input.form-control(type="text" name="name" value=product.name required)
          .form-group
            label МНН
            input.form-control(type="text" name="inn_name" value=product.inn_name || '')
        
        .form-row
          .form-group
            label Группа *
            select.form-control(name="group_id" required)
              each g in groups
                option(value=g.id selected=(product.group_id == g.id))= g.name
          .form-group
            label Производитель
            input.form-control(type="text" name="manufacturer" value=product.manufacturer || '')
        
        .form-row-3
          .form-group
            label Форма выпуска
            input.form-control(type="text" name="form" value=product.form || '')
          .form-group
            label Дозировка
            input.form-control(type="text" name="dosage" value=product.dosage || '')
          .form-group
            label Штрихкод
            input.form-control(type="text" name="barcode" value=product.barcode || '')
        
        .form-row
          .form-group
            label Цена (₽) *
            input.form-control(type="number" name="price" step="0.01" min="0" value=product.price required)
          .form-group(style="display:flex;align-items:flex-end;gap:8px")
            label
              input(type="checkbox" name="is_prescription" value="1" checked=product.is_prescription)
              |  По рецепту
        
        .form-group
          label Изображение товара
          if product.image
            div(style="margin-bottom:10px")
              img(src=`/uploads/products/${product.image}` width="100" style="border-radius:4px")
              br
              small.text-muted Текущее изображение
          input.form-control(type="file" name="image" accept="image/*")
        
        .form-group
          label Описание
          textarea.form-control(name="description" rows="3")= product.description || ''
        
        div(style="margin-top:16px;display:flex;gap:8px")
          button.btn.btn-primary(type="submit") Сохранить
          a.btn.btn-secondary(href="/admin/products") Отмена
    else
      form(action="/admin/products" method="POST" enctype="multipart/form-data")
        .form-row
          .form-group
            label Наименование *
            input.form-control(type="text" name="name" required)
          .form-group
            label МНН
            input.form-control(type="text" name="inn_name")
        
        .form-row
          .form-group
            label Группа *
            select.form-control(name="group_id" required)
              each g in groups
                option(value=g.id)= g.name
          .form-group
            label Производитель
            input.form-control(type="text" name="manufacturer")
        
        .form-row-3
          .form-group
            label Форма выпуска
            input.form-control(type="text" name="form")
          .form-group
            label Дозировка
            input.form-control(type="text" name="dosage")
          .form-group
            label Штрихкод
            input.form-control(type="text" name="barcode")
        
        .form-row
          .form-group
            label Цена (₽) *
            input.form-control(type="number" name="price" step="0.01" min="0" required)
          .form-group(style="display:flex;align-items:flex-end;gap:8px")
            label
              input(type="checkbox" name="is_prescription" value="1")
              |  По рецепту
        
        .form-group
          label Изображение товара
          input.form-control(type="file" name="image" accept="image/*")
        
        .form-group
          label Описание
          textarea.form-control(name="description" rows="3")
        
        div(style="margin-top:16px;display:flex;gap:8px")
          button.btn.btn-primary(type="submit") Сохранить
          a.btn.btn-secondary(href="/admin/products") Отмена