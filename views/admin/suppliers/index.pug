extends ../../layout

block content
  h2.page-title Поставщики
  div(style="margin-bottom:16px")
    a.btn.btn-primary(href="/admin/suppliers/new") + Добавить поставщика
  .card
    .table-wrap
      table
        thead
          tr
            th Название
            th ИНН
            th Телефон
            th Email
            th Адрес
            th Действия
        tbody
          each s in suppliers
            tr
              td= s.name
              td= s.inn || '—'
              td= s.phone || '—'
              td= s.email || '—'
              td= s.address || '—'
              td
                a.btn.btn-secondary.btn-sm(href=`/admin/suppliers/${s.id}/edit`) Изменить
                form(action=`/admin/suppliers/${s.id}/delete` method="POST" style="display:inline;margin-left:4px")
                  button.btn.btn-danger.btn-sm(type="submit" onclick="return confirm('Удалить поставщика?')") Удалить