extends ../layout

block content
  a.btn.btn-secondary.btn-sm(href="/" style="margin-bottom:16px") ← Каталог
  .card
    h2.page-title= product.product_name
    
    .form-row(style="display: flex; gap: 30px; flex-wrap: wrap;")
      // Блок с изображением
      div(style="flex: 0 0 200px;")
        if product.image
          img(src=`/uploads/products/${product.image}` 
              style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" 
              alt=product.product_name)
        else
          div(style="width: 100%; background: #f5f5f5; border-radius: 8px; display: flex; align-items: center; justify-content: center; min-height: 200px;")
            span(style="color: #999;") Нет фото
      
      // Блок с характеристиками
      div(style="flex: 1;")
        table(style="width:100%")
          tr
            th МНН
            td= product.inn_name || '—'
          tr
            th Группа
            td= product.group_name
          tr
            th Производитель
            td= product.manufacturer || '—'
          tr
            th Форма выпуска
            td= product.form || '—'
          tr
            th Дозировка
            td= product.dosage || '—'
          tr
            th Штрихкод
            td= product.barcode || '—'
          tr
            th Тип отпуска
            td
              span(class=`badge ${product.is_prescription ? 'badge-rx' : 'badge-otc'}`)
                = product.is_prescription ? 'По рецепту' : 'Без рецепта'
          tr
            th Остаток
            td
              if product.quantity > 0
                | #{product.quantity} шт.
              else
                span(style="color:#dc3545") Нет в наличии
          tr
            th Цена
            td(style="font-size:22px;font-weight:700;color:#1a6b3c") #{Number(product.price).toFixed(2)} ₽

    if product.description
      div(style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #eee;")
        p(style="color:#666;font-size:13px;line-height:1.6")= product.description

    if user && user.role === 'customer' && product.quantity > 0
      div(style="margin-top:16px")
        a.btn.btn-primary(href="/orders/new") Забронировать